{	
	"config":{
		"prod_env": true,
		"ssl": {
			"key":"/etc/ssl/cf-privkey-brasaz.pem",
			"cert":"/etc/ssl/cf-fullchain-brasaz.pem"
		},
		
		"webserver_port": 443,
		"web_folder": "/var/webserver/https",

		"epanel_enabled": true,
		"epanel_subdomain": "epanel",
		"epanel_folder": "/var/webserver/ehecatl/panel",

		"datetime_timezone": "America/Sao_Paulo",
		"datetime_lang": "pt-BR",
		"lang_default": "pt-br",
		"session_path": "/cloud",

		"route_version": {
			"default": "001",
			"www.pecrodrigues.com.br": "001",
			"www.brasaz.com.br": "001"
		},
	},

	"scripts":{
		"validator": "./utils/validator.js",
		"filesystem": "./utils/filesystem.js",

		"responser": "./controllers/responser.js",

		"router": "./middleware/router.js",
		
		"cdn": "./services/cdn.js",
		"debug": "./services/debug.js",
		"crawler": "./services/crawler.js",
		"autobackup": "./services/autobackup.js",
	}
}