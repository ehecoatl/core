{
  "name": "WOLIMP",
  "short_name": "WOLIMP",
  "start_url": "/",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "display": "standalone",
  "theme_color": "#FFFFFF",
  "background_color": "#FFFFFF",
  "description": "WOLIMP Editor",
  "serviceworker": "/service-worker.js?uuid={{¡uuid_sw!}}",
  "protocol_handlers": [
    {
      "protocol": "web+wolimpapp",
      "url": "/?ref=%s"
    }
  ],
  "launch_handler": {
    "client_mode": ["focus-existing"]
  },
  "icons": [
    {
      "src": "/assets/img/app-icon-512.png?uuid={{¡uuid_img!}}",
      "type": "image/png",
      "sizes": "512x512",
      "purpose": "any"
    },
    {
      "src": "/assets/img/app-icon-192.png?uuid={{¡uuid_img!}}",
      "type": "image/png",
      "sizes": "192x192",
      "purpose": "any"
    }
  ]
}