{
  "name": "Ehecoatl",
  "version": "{{version}}",
  "description": "Multi-tenant Node.js web hosting engine for HTTP\nand WebSocket applications, designed for architectural solidity,\nhigh performance, and agile configuration and maintenance.",
  "main": "./index.js",
  "scripts": {
    "build:seccomp-addon": "node ./scripts/build-seccomp-addon.js",
    "perf:stability": "node scripts/perf-stability.js",
    "perf:stability:quick": "node scripts/perf-stability.js --quick",
    "postinstall": "node ./scripts/build-seccomp-addon.js",
    "format": "prettier --log-level warn --write \"./**/*.{jsx,js}\"",
    "test": "node --test"
  },
  "author": "Pec Rodrigues",
  "license": "Apache-2.0",
  "dependencies": {
    "figlet": "~1.10.0",
    "module-alias": "~2.3.4",
    "redis": "~5.11.0",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.57.0"
  },
  "devDependencies": {
    "@types/node": "~20.0.0",
    "node-gyp": "~11.2.0",
    "prettier": "~3.8.1"
  },
  "_moduleAliases": {
    "@package.json": "package.json",
    "@": ".",
    "@middleware": "./builtin-extensions/middlewares",
    "@adapter": "./builtin-extensions/adapters",
    "@plugin": "./builtin-extensions/plugins"
  }
}
