{	
	"config":{
		"prod_env": true,
		"ssl": {
			"key":"/etc/ssl/cf-privkey-brasaz.pem",
			"cert":"/etc/ssl/cf-fullchain-brasaz.pem"
		},
		
		"webserver_port": 443,
		"trust_proxy": true,
		"web_folder": "/var/webserver/https",

		"websocket_ports": [ 8443 ], /*, 2053, 2083, 2087, 2096*/

		"epanel_enabled": true,
		"epanel_subdomain": "epanel",
		"epanel_folder": "/var/webserver/ehecatl/epanel",

		"datetime_timezone": "America/Sao_Paulo",
		"datetime_lang": "pt-BR",
		"lang_default": "pt-br",

		"route_version_default": "001"
	},

	"scripts":{
		"debug": "./utils/debug.js",
		"functions": "./utils/functions.js",
		"validator": "./utils/validator.js",
		"filesystem": "./utils/filesystem.js",
		"autobackup": "./utils/autobackup.js",

		"responser": "./responses/responser.js",

		"router": "./middleware/router.js",
		
		"crawler": "./services/crawler.js",
	}
}