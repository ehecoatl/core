{
    "compilerOptions": {
        "module": "Node16",
        "moduleResolution": "node16",
        "target": "ES2024",
        "allowJs": true,
        "checkJs": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@package.json": [
                "./ehecoatl-runtime/package.json"
            ],
            "@middleware*": [
                "./ehecoatl-runtime/builtin-extensions/middlewares*"
            ],
            "@adapter*": [
                "./ehecoatl-runtime/builtin-extensions/adapters*"
            ],
            "@plugin*": [
                "./ehecoatl-runtime/builtin-extensions/plugins*"
            ],
            "@*": [
                "./ehecoatl-runtime*"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "**/node_modules",
        "**/_backup",
    ]
}