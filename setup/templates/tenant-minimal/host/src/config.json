{
  "methodsAvailable": [
    "GET",
    "POST"
  ],
  "routesAvailable": {
    "/": {
      "redirect": "/htm/index.htm",
      "status": 302,
      "methods": [
        "GET"
      ]
    },
    "/htm/{filename}.htm": {
      "asset": "htm/{filename}.htm",
      "cache": "public",
      "methods": [
        "GET"
      ]
    },
    "/session": {
      "controller": "controllers/sessionController.js",
      "call": "index",
      "session": true,
      "cache": "no-cache",
      "methods": [
        "GET"
      ]
    },
    "/post-data": {
      "controller": "controllers/postDataController.js",
      "call": "index",
      "cache": "no-cache",
      "methods": [
        "POST"
      ],
      "content-types": [
        "application/json",
        "application/x-www-form-urlencoded"
      ]
    },
    "/{controller}": {
      "controller": "controllers/{controller}Controller.js",
      "call": "index",
      "cache": "no-cache",
      "methods": [
        "GET"
      ]
    }
  }
}